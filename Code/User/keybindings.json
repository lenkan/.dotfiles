// Place your key bindings in this file to override the defaultsauto[]
[
  // === Command palette ===
  {
    "key": "ctrl+space space",
    "command": "workbench.action.showCommands"
  },
  {
    "key": "f1",
    "command": "-workbench.action.showCommands"
  },

  // === Leader: focus views ===
  {
    "key": "ctrl+space ctrl+f",
    "command": "workbench.files.action.focusFilesExplorer"
  },
  {
    "key": "ctrl+space ctrl+t",
    "command": "workbench.action.terminal.focus"
  },

  // === Leader: window/group navigation (hjkl) ===
  {
    "key": "ctrl+space ctrl+h",
    "command": "workbench.action.focusLeftGroup"
  },
  {
    "key": "ctrl+space ctrl+j",
    "command": "workbench.action.focusBelowGroup"
  },
  {
    "key": "ctrl+space ctrl+k",
    "command": "workbench.action.focusAboveGroup"
  },
  {
    "key": "ctrl+space ctrl+l",
    "command": "workbench.action.focusRightGroup"
  },
  {
    "key": "ctrl+space ctrl+e",
    "command": "workbench.action.focusActiveEditorGroup"
  },

  // === Leader: editor splits ===
  {
    "key": "ctrl+space shift+7",
    "command": "workbench.action.moveEditorToRightGroup"
  },
  {
    "key": "ctrl+space -",
    "command": "workbench.action.moveEditorToBelowGroup"
  },

  // === Leader: panels & sidebars ===
  {
    "key": "ctrl+space ctrl+s",
    "command": "workbench.action.toggleSidebarVisibility"
  },
  {
    "key": "ctrl+space ctrl+a",
    "command": "workbench.action.toggleAuxiliaryBar"
  },
  {
    "key": "ctrl+space ctrl+p",
    "command": "workbench.action.togglePanel"
  },
  {
    "key": "ctrl+space ctrl+c",
    "command": "claudeVSCodeSidebarSecondary.focus"
  },

  // === Diagnostics: next/prev marker ===
  {
    "key": "alt+oem_2",
    "command": "editor.action.marker.next",
    "when": "editorFocus"
  },
  {
    "key": "alt+f8",
    "command": "-editor.action.marker.next",
    "when": "editorFocus"
  },
  {
    "key": "shift+alt+oem_2",
    "command": "editor.action.marker.prev"
  },
  {
    "key": "shift+alt+f8",
    "command": "-editor.action.marker.prev",
    "when": "editorFocus"
  },

  // === Code actions / quick fix (alt+enter) ===
  {
    "key": "alt+enter",
    "command": "problems.action.showQuickFixes",
    "when": "problemFocus"
  },
  {
    "key": "ctrl+[Period]",
    "command": "-problems.action.showQuickFixes",
    "when": "problemFocus"
  },
  {
    "key": "alt+enter",
    "command": "editor.action.quickFix",
    "when": "editorHasCodeActionsProvider && editorTextFocus && !editorReadonly"
  },
  {
    "key": "ctrl+[Period]",
    "command": "-editor.action.quickFix",
    "when": "editorHasCodeActionsProvider && editorTextFocus && !editorReadonly"
  },
  {
    "key": "shift+alt+[IntlBackslash]",
    "command": "-editor.action.autoFix",
    "when": "editorTextFocus && !editorReadonly && supportedCodeAction =~ /(\\s|^)quickfix\\b/"
  },

  // === Suggestions & parameter hints ===
  {
    "key": "ctrl+space i",
    "command": "editor.action.triggerParameterHints",
    "when": "editorHasSignatureHelpProvider && editorTextFocus"
  },
  {
    "key": "ctrl+shift+space",
    "command": "-editor.action.triggerParameterHints",
    "when": "editorHasSignatureHelpProvider && editorTextFocus"
  },
  {
    "key": "ctrl+space j",
    "command": "editor.action.triggerSuggest",
    "when": "editorHasCompletionItemProvider && textInputFocus && !editorReadonly"
  },
  {
    "key": "ctrl+i",
    "command": "-editor.action.triggerSuggest",
    "when": "editorHasCompletionItemProvider && textInputFocus && !editorReadonly"
  },
  {
    "key": "ctrl+space",
    "command": "-editor.action.triggerSuggest",
    "when": "editorHasCompletionItemProvider && textInputFocus && !editorReadonly"
  },

  // === Format document ===
  {
    "key": "ctrl+k d",
    "command": "editor.action.formatDocument",
    "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
  },
  {
    "key": "ctrl+shift+i",
    "command": "-editor.action.formatDocument",
    "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
  },

  // === Vim ctrl+p remap ===
  {
    "key": "ctrl+shift+p ctrl+shift+d",
    "command": "extension.vim_ctrl+p",
    "when": "editorTextFocus && vim.active && vim.use<C-p> && !inDebugRepl || vim.active && vim.use<C-p> && !inDebugRepl && vim.mode == 'CommandlineInProgress' || vim.active && vim.use<C-p> && !inDebugRepl && vim.mode == 'SearchInProgressMode'"
  },
  {
    "key": "ctrl+p",
    "command": "-extension.vim_ctrl+p",
    "when": "editorTextFocus && vim.active && vim.use<C-p> && !inDebugRepl || vim.active && vim.use<C-p> && !inDebugRepl && vim.mode == 'CommandlineInProgress' || vim.active && vim.use<C-p> && !inDebugRepl && vim.mode == 'SearchInProgressMode'"
  },

  // === Postgres: run query ===
  {
    "key": "f5",
    "command": "vscode-postgres.runQuery",
    "when": "editorLangId == 'postgres' || editorLangId === 'sql'"
  },
  {
    "key": "f5",
    "command": "-vscode-postgres.runQuery",
    "when": "editorLangId == 'postgres'"
  },

  // === Default unbinds ===
  {
    "key": "ctrl+w",
    "command": "-workbench.action.closeActiveEditor"
  },
  {
    "key": "ctrl+o",
    "command": "-workbench.action.files.openFile",
    "when": "true"
  }
]
